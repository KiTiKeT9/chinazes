{
  "name": "chinazes",
  "version": "1.6.0",
  "description": "Desktop hub for Telegram, Discord, YouTube and TikTok with built-in v2ray/Xray proxy (app-scoped, not system-wide).",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.chinazes.app",
    "productName": "Chinazes",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/xray",
        "to": "xray",
        "filter": [
          "**/*",
          "!*.md",
          "!*.txt"
        ]
      },
      {
        "from": "resources/psiphon",
        "to": "psiphon",
        "filter": [
          "**/*",
          "!*.md",
          "!*.txt"
        ]
      },
      {
        "from": "resources/warp-plus",
        "to": "warp-plus",
        "filter": [
          "**/*",
          "!*.md"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chinazes"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "KiTiKeT9",
        "repo": "chinazes"
      }
    ]
  }
}
